{
  "name": "@tdb/slc-fs",
  "version": "0.0.181",
  "license": "MIT",
  "private": true,
  "tasks": {
    "test": "echo no-op",
    "build": "deno run -P=build ./-scripts/-build.ts && deno task info",
    "serve": "deno run -P=serve ./-scripts/-serve.ts",
    "deploy": "deno task build && orbiter deploy && deno task info",
    "clean": "deno run -P=clean ./-scripts/-clean.ts",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "info": "deno run -P=dev ./-scripts/-help.ts",
    "tmp": "deno run -A ./-scripts/-tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts"
  },
  "permissions": {
    "build": {
      "read": true,
      "write": true,
      "env": true
    },
    "serve": {
      "read": true,
      "net": true
    },
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "dev": {
      "read": true,
      "env": true
    }
  }
}

