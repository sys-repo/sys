{
  // --- Deno -------------------------------------------------
  "deno.enable": false,
  "deno.lint": false,
  "deno.importMap": "imports.json",
  "deno.enablePaths": ["code", "deploy", "-scripts"],
  "deno.disablePaths": ["node_modules", "**/dist", "**/.vite", "**/coverage", "-tmp", "-tmp/**"],

  // --- Editor (quality of life) -----------------------------
  "editor.snippetSuggestions": "top",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.quickSuggestionsDelay": 0,

  // --- Formatting -------------------------------------------
  "editor.formatOnSave": true,
  "editor.formatOnPaste": false,
  "editor.defaultFormatter": "denoland.vscode-deno",
  "[typescript]": { "editor.defaultFormatter": "denoland.vscode-deno" },
  "[javascript]": { "editor.defaultFormatter": "denoland.vscode-deno" },
  "[typescriptreact]": { "editor.defaultFormatter": "denoland.vscode-deno" },
  "[javascriptreact]": { "editor.defaultFormatter": "denoland.vscode-deno" },

  "editor.codeActionsOnSave": {
    "source.organizeImports": "never",
    "source.removeUnusedImports": "never",
    "source.fixAll": "never"
  },

  "[markdown]": {
    "editor.formatOnSave": false,
    "files.trimTrailingWhitespace": false
  },

  // --- File-system hygiene ----------------------------------
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.vite/**": true,
    "**/coverage/**": true
  },
  "search.exclude": {
    "-tmp": true,
    "**/.tmp": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.vite": true,
    "**/coverage": true
  }
}
