{
  // --- Deno -------------------------------------------------
  "deno.enable": false,
  "deno.lint": false,
  "deno.importMap": "deno.imports.json",
  "deno.unstable": true,
  "deno.enablePaths": ["code", "deploy", "-scripts"],
  "deno.disablePaths": ["node_modules", "**/dist", "**/.vite", "**/coverage", "-tmp", "-tmp/**"],

  "deno.enablePathsRefactor": false, // NB: Deno LSP is too slow to make this useful.

  // --- Editor QoL -------------------------------------------
  "editor.snippetSuggestions": "top",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.quickSuggestionsDelay": 0,

  // --- File System hygiene ----------------------------------
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.vite/**": true,
    "**/coverage/**": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.vite": true,
    "**/coverage": true,
    "-tmp": true
  }
}
