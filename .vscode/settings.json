{
  // --- Deno -------------------------------------------------
  "deno.enable": false,
  "deno.lint": false,
  "deno.importMap": "deno.imports.json",
  "deno.enablePaths": ["code", "deploy", "-scripts"],
  "deno.disablePaths": ["node_modules", "**/dist", "**/.vite", "**/coverage", "-tmp", "-tmp/**"],

  // --- Editor (quality of life) -------------------------------------------
  "editor.snippetSuggestions": "top",
  "editor.suggest.snippetsPreventQuickSuggestions": false,
  "editor.quickSuggestionsDelay": 0,

  // --- Formatting ----------------------------------
  "[markdown]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": null,
    "files.trimTrailingWhitespace": false
  },

  // --- File-system Hygiene ----------------------------------
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/dist/**": true,
    "**/.vite/**": true,
    "**/coverage/**": true
  },
  "search.exclude": {
    "-tmp": true,
    "**/.tmp": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.vite": true,
    "**/coverage": true
  }
}
