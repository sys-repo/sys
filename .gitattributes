# Enforce consistent line endings
* text=auto

# Track large images with Git LFS (large-file-storage):
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.webm filter=lfs diff=lfs merge=lfs -text
deploy/**/*.pdf   filter=lfs diff=lfs merge=lfs -text
deploy/**/*.png   filter=lfs diff=lfs merge=lfs -text
deploy/**/*.jpg   filter=lfs diff=lfs merge=lfs -text
deploy/**/*.jpeg  filter=lfs diff=lfs merge=lfs -text
deploy/**/*.svg   filter=lfs diff=lfs merge=lfs -text
deploy/**/*.gif   filter=lfs diff=lfs merge=lfs -text

# Keep this publishable SVG as normal git text so the generated TS surface can
# be rebuilt from source without LFS pointer drift.
deploy/@tdb.slc.std/src/ui/ui.Logo.Canvas/canvas.mini.svg -filter -diff -merge text
