import { type t, Fs } from './common.ts';
import { YamlConfig } from '@sys/yaml/cli';
import { __NAME__Fs, __NAME__YamlSchema } from './u.yaml/mod.ts';

export type YamlConfigsMenuPick =
  | { readonly kind: 'exit' }
  | { readonly kind: 'selected'; readonly key: string };

type Action = 'select';

const ValidName = {
  hint: 'letters, numbers, ".", "_" or "-"',
  test(value: string) {
    return /^[a-zA-Z0-9]+([._-][a-zA-Z0-9]+)*$/.test(value);
  },
} as const;

export async function yamlConfigsMenu(cwd: t.StringDir): Promise<YamlConfigsMenuPick> {
  const schema = {
    init: () => __NAME__YamlSchema.initial(),
    validate: (value: unknown) => __NAME__YamlSchema.validate(value),
  } as const;

  const res = await YamlConfig.menu<t.__NAME__Tool.ConfigYaml.Doc, Action>({
    cwd,
    dir: __NAME__Fs.dir,
    label: '__NAME__ Config',
    itemLabel: 'config',
    addLabel: '   add: <config>',
    ensureDefault: false,
    schema,
    mode: 'select',
    selectAction: 'select',
    add: {
      message: 'Config name',
      hint: ValidName.hint,
      validate(value) {
        if (!ValidName.test(value)) return ValidName.hint;
        return true;
      },
      initYaml: ({ name: configName }) => __NAME__Fs.initialYaml(configName),
    },
  });

  if (res.kind === 'exit') return { kind: 'exit' };
  if (res.kind !== 'action' || res.action !== 'select') return { kind: 'exit' };
  return { kind: 'selected', key: nameFromPath(res.path) };
}

function nameFromPath(path: t.StringPath): string {
  const base = Fs.basename(path);
  return base.endsWith(__NAME__Fs.ext) ? base.slice(0, -__NAME__Fs.ext.length) : base;
}
