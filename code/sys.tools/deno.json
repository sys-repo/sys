{
  "name": "@sys/tools",
  "version": "0.0.277",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "prep": "deno run -P=dev ./-scripts/task.prep.ts && deno run -P=dev ./src/-tmpl/mod.ts",
    "tmpl": "deno run -P=dev ./src/-tmpl.cli/mod.ts",
    "help": "deno run -P=dev ./src/mod.ts --help",
    "tmp": "deno run -P=dev ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./cp": "./src/cli.clipboard/mod.ts",
    "./copy": "./src/cli.clipboard/mod.ts",
    "./crdt": "./src/cli.crdt/mod.ts",
    "./video": "./src/cli.video/mod.ts",
    "./serve": "./src/cli.serve/mod.ts",
    "./deploy": "./src/cli.deploy/mod.ts",
    "./up": "./src/cli.update/mod.ts",
    "./update": "./src/cli.update/mod.ts",
    "./env": "./src/-exports/-env.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true,
      "run": true
    },
    "dev": {
      "read": true,
      "write": true,
      "run": true,
      "env": true,
      "net": true
    }
  }
}
