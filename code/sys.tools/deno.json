{
  "name": "@sys/tools",
  "version": "0.0.181",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=testset",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/-clean.ts",
    "prep": " deno run -RWE ./src/-tmpl/bundle/mod.ts",
    "tmpl": "deno run -P=ci ./src/-tmpl/-tmpl.cli/mod.ts",
    "help": "deno run -P=dev   ./-scripts/-vite.ts --cmd=help",
    "tmp": "deno run -P=ci ./-scripts/-tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./cp": "./src/cli.clipboard/mod.ts",
    "./copy": "./src/cli.clipboard/mod.ts",
    "./crdt": "./src/cli.crdt/mod.ts",
    "./fs": "./src/cli.fs/mod.ts",
    "./video": "./src/cli.video/mod.ts",
    "./serve": "./src/cli.serve/mod.ts",
    "./deploy": "./src/cli.deploy/mod.ts",
    "./up": "./src/cli.update/mod.ts",
    "./update": "./src/cli.update/mod.ts",
    "./env": "./src/-exports/-env.ts",
    "./staging/prog": "./-staging.prog/mod.ts"
  }
}
