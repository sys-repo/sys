{
  "name": "@sys/tmpl",
  "version": "0.0.262",
  "license": "MIT",
  "tasks": {
    "test": "deno test -RWNE --allow-run --allow-ffi --allow-sys",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -RWE ./-scripts/task.clean.ts",
    "tmpl": "deno run -RWE ./src/mod.ts",
    "prep": "deno task clean && deno run -RWE ./-scripts/task.prep.ts && deno run -RWE ./src/mod.ts --bundle",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts"
  }
}
