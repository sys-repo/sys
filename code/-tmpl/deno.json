{
  "name": "@sys/tmpl",
  "version": "0.0.291",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "tmpl": "deno run -P=tmpl ./src/mod.ts",
    "prep": "deno task clean && deno run -P=prep ./-scripts/task.prep.ts",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./testing": "./src/m.testing/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "tmpl": {
      "read": true,
      "write": true,
      "env": true
    },
    "prep": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "run": true
    }
  }
}
