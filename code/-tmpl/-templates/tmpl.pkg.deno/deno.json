{
  "name": "@sample/foo",
  "version": "0.0.0",
  "license": "MIT",
  "tasks": {
    "dev": "deno run --allow-ffi -P=dev ./-scripts/task.vite.ts --cmd=dev --in=./src/-test/index.html",
    "test": "deno test -P=test",
    "build": "deno run --allow-ffi -P=dev ./-scripts/task.vite.ts --cmd=build --in=./src/-test/index.html",
    "serve": "deno run --allow-ffi -P=dev ./-scripts/task.vite.ts --cmd=serve",

    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "help": "deno run --allow-ffi -P=dev   ./-scripts/task.vite.ts --cmd=help",

    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "permissions": {
    "test": { "read": true, "env": true },
    "dev": { "read": true, "write": true, "run": true, "env": true, "net": true },
    "clean": { "read": true, "write": true }
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts"
  }
}
