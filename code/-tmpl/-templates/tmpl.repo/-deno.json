{
  "tasks": {
    "ci": "deno task check && deno task test",
    "check": "deno check",
    "test": "deno test -P=test ./-scripts ./code",
    "prep": "deno run -P=test ./-scripts/task.prep.ts",
    "tmpl": "deno run -P=tmpl ./-scripts/task.tmpl.ts",
    "tmpl:project": "deno run -P=tmpl ./-scripts/task.tmpl.ts pkg",
    "outdated": "deno outdated",
    "upgrade": "deno update --latest",
    "tmp": "deno run -A ./-scripts/tmp.ts"
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "esnext",
      "dom",
      "dom.iterable",
      "dom.asynciterable",
      "webworker",
      "deno.ns"
    ],
    "types": [
      "npm:@types/react",
      "npm:@types/react-dom"
    ],
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "nodeModulesDir": "auto",
  "importMap": "imports.json",
  "permissions": {
    "test": { "read": true, "write": true, "env": true },
    "tmpl": { "read": true, "write": true, "run": true, "env": true }
  },
  "workspace": []
}
