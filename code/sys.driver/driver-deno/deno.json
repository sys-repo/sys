{
  "name": "@sys/driver-deno",
  "version": "0.0.269",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "test:external": "deno task test --trace-leaks ./src/m.cloud/m.DenoDeploy/-test/-external.ts",
    "prep": "deno run -P=prep ./-scripts/task.prep.ts",
    "check": "deno check src/*",
    "dry": "deno publish --allow-dirty --dry-run",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./cloud": "./src/m.cloud/mod.ts",
    "./runtime": "./src/m.runtime/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "prep": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "run": true,
      "net": true
    }
  }
}
