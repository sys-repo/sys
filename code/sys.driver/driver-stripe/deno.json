{
  "name": "@sys/driver-stripe",
  "version": "0.0.73",
  "license": "MIT",
  "x-sys": {
    "ci": {
      "test": {
        "browser": true
      }
    }
  },
  "tasks": {
    "dev": "deno run -P=dev ./-scripts/task.vite.ts --cmd=dev --in=./src/index.html",
    "test": "deno task test:unit && deno task build && deno task test:dist",
    "test:unit": "deno test -P=test",
    "test:dist": "SYS_DRIVER_STRIPE_BROWSER_DIST=1 deno test -P=test-dist --trace-leaks ./src/ui/ui.PaymentElement/-test/-spec.bundle.test.ts ./src/ui/ui.PaymentElement/-test/-dist.browser.test.ts",
    "verify": "deno task check && deno task test",
    "build": "deno run -P=dev ./-scripts/task.vite.ts --cmd=build --in=./src/index.html",
    "serve": "deno run -P=dev ./-scripts/task.vite.ts --cmd=serve",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "info": "deno run -P=dev   ./-scripts/task.vite.ts --cmd=info",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./ui": "./src/ui/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true
    },
    "test-dist": {
      "read": true,
      "write": true,
      "env": true,
      "net": true,
      "run": true
    },
    "dev": {
      "read": true,
      "write": true,
      "run": true,
      "env": true,
      "net": true,
      "ffi": true,
      "sys": {
        "allow": [
          "cpus",
          "networkInterfaces",
          "hostname",
          "osRelease",
          "homedir",
          "uid",
          "gid"
        ]
      }
    }
  }
}

