{
  "name": "@sys/driver-vite",
  "version": "0.0.390",
  "license": "MIT",
  "tasks": {
    "ci": "deno task check && deno task test && deno task test:external && deno task clean",
    "prep": "deno run -P=dev ./-scripts/task.prep.ts",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check --node-modules-dir=auto src/*",
    "test": "deno test --node-modules-dir=auto -P=test",
    "test:external": "deno task test --trace-leaks ./src/m.vite/-test.external/mod.ts",
    "perf": "deno run -P=dev ./-scripts/task.perf.ts",
    "smoke": "deno run -P=dev ./-scripts/task.smoke.ts",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "info": "deno run -P=dev ./-scripts/task.main.ts --cmd=info    --dir=./src/-test/vite.sample-1",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./config": "./src/m.vite.config/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./entry": "./src/-entry/mod.ts",
    "./main": "./src/-entry/-main.ts",
    "./plugins": "./src/m.vite.plugins/mod.ts",
    "./sample-imports": "./src/-test/-sample-imports.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true,
      "run": true,
      "ffi": true,
      "sys": {
        "allow": [
          "cpus",
          "networkInterfaces",
          "hostname",
          "osRelease",
          "homedir",
          "uid",
          "gid"
        ]
      }
    },
    "dev": {
      "read": true,
      "write": true,
      "run": true,
      "env": true,
      "net": true,
      "ffi": true,
      "sys": {
        "allow": [
          "cpus",
          "networkInterfaces",
          "hostname",
          "osRelease",
          "homedir",
          "uid",
          "gid"
        ]
      }
    }
  }
}

