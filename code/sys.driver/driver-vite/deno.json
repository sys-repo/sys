{
  "name": "@sys/driver-vite",
  "version": "0.0.296",
  "license": "MIT",
  "tasks": {
    "prep": "deno run -P=dev ./-scripts/task.prep.ts",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check --node-modules-dir=auto src/*",
    "test": "deno test --node-modules-dir=auto -P=testset",
    "smoke:published": "deno task test --trace-leaks ./src/m.vite/-test/-bridge.published.integration.ts",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "help": "deno run -P=dev ./-scripts/task.main.ts --cmd=help    --dir=./.tmp/sample",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./entry": "./src/-entry/mod.ts",
    "./main": "./src/-entry/-main.ts",
    "./sample-imports": "./src/-test/-sample-imports.ts"
  }
}
