{
  "name": "@sys/driver-vite",
  "version": "0.0.289",
  "license": "MIT",
  "tasks": {
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "test": "deno test -P=testset",
    "clean": "deno run -P=clean ./-scripts/-main.ts --cmd=clean",
    "help": "deno run -P=dev ./-scripts/-main.ts --cmd=help    --dir=./.tmp/sample",
    "tmp": "deno run -A ./-scripts/-tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./entry": "./src/-entry/mod.ts",
    "./main": "./src/-entry/-main.ts",
    "./sample-imports": "./src/-test/-sample-imports.ts"
  }
}
