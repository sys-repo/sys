{
  "name": "@sys/driver-automerge",
  "version": "0.0.204",
  "license": "MIT",
  "tasks": {
    "dev": "deno run -P=dev   ./-scripts/task.main.ts --cmd=dev    --in=./src/-test/index.html",
    "test": "deno test -P=test --unstable-worker-options",
    "build": "deno run -P=dev ./-scripts/task.main.ts --cmd=build  --in=./src/-test/index.html",
    "serve": "deno run -P=dev ./-scripts/task.main.ts --cmd=serve",
    "ws": "deno run -P=ws @sys/driver-automerge/ws --port=3030 --dir=.tmp/sync.crdt",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "help": "deno run -P=dev   ./-scripts/task.main.ts --cmd=help",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./debug": "./src/m.Debug/mod.ts",
    "./fs": "./src/-exports/-fs/mod.ts",
    "./web": "./src/-exports/-web/mod.ts",
    "./web/ui": "./src/-exports/-web.ui/mod.ts",
    "./ws": "./src/-exports/-ws.ts",
    "./ws/client": "./src/-exports/-ws.client.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    },
    "ws": {
      "read": true,
      "write": true,
      "net": true
    },
    "dev": {
      "read": true,
      "write": true,
      "run": true,
      "env": true,
      "net": true,
      "ffi": true,
      "sys": {
        "allow": [
          "cpus",
          "networkInterfaces",
          "hostname",
          "osRelease",
          "homedir",
          "uid",
          "gid"
        ]
      }
    }
  }
}
