{
  "name": "@sys/cell",
  "version": "0.0.8",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test ./src",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check -- ./src/ ./-scripts/*",
    "cli": "deno run ./src/m.cli/mod.ts",
    "pi": "cd ./-sample && deno run -A @sys/driver-pi Profiles --git-root none --config ./-config/sample.yaml --",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "prep": "deno task tmpl:bundle",
    "tmpl:bundle": "deno run -RWE ./src/m.tmpl/mod.ts",
    "start": "deno task sample:stripe",
    "sample:stripe": "deno run -P=sample ./-scripts/task.sample.ts",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./cli": "./src/m.cli/mod.ts"
  },
  "exclude": [
    "-sample/.pi"
  ],
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "sample": {
      "read": true,
      "write": true,
      "env": true,
      "net": true,
      "run": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    }
  }
}
