{
  "name": "@sys/cell",
  "version": "0.0.1",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check -- ./src/ ./-scripts/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "tmp": "deno run -A ./-scripts/task.tmp.ts",
    "sample": "deno run -P=sample @sys/tools serve --non-interactive --config ./-sample/cell.stripe/-config/@sys.tools.serve/view.yaml"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts"
  },
  "permissions": {
    "clean": { "read": true, "write": true, "env": true },
    "sample": { "read": true, "write": true, "env": true, "net": true, "run": true },
    "test": { "read": true, "write": true, "env": true }
  }
}
