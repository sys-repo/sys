{
  "name": "@sys/testing",
  "version": "0.0.244",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "dry": "deno publish --allow-dirty --dry-run",
    "clean": "deno run -P=clean ./scripts/task.clean.ts"
  },
  "exports": {
    ".": "./src/ns.client/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./spec": "./src/ns.client/m.Spec/mod.ts",
    "./server": "./src/ns.server/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    }
  }
}
