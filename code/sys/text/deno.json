{
  "name": "@sys/text",
  "version": "0.0.245",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "dry": "deno publish --allow-dirty --dry-run",
    "clean": "deno run -P=clean ./scripts/task.clean.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./diff": "./src/-exports/-diff.ts",
    "./filter": "./src/-exports/-filter.ts",
    "./gpt": "./src/-exports/-gpt.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true
    }
  }
}
