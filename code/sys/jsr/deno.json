{
  "name": "@sys/jsr",
  "version": "0.0.230",
  "license": "MIT",
  "tasks": {
    "dry": "deno publish --allow-dirty --dry-run",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "test": "deno test -P=test",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/m.client/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./client": "./src/m.client/mod.ts",
    "./server": "./src/m.server/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    }
  }
}
