  "tasks": {
    "dry": "deno publish --allow-dirty --dry-run",
    "clean": "deno run -P=clean ./scripts/task.clean.ts",
    "test": "deno test -P=test"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./fmt": "./src/m.Fmt/mod.ts",
    "./hash": "./src/m.Hash/mod.ts",
    "./sign": "./src/mod.sign.ts",
    "./sign/ed25519": "./src/m.Sign.Ed25519/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true
    }
  }
}
