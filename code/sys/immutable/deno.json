{
  "name": "@sys/immutable",
  "version": "0.0.45",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=testset --unstable-worker-options",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/-clean.ts",
    "tmp": "deno run -A ./-scripts/-tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./core": "./src/-exports/-core.ts",
    "./graph": "./src/-exports/-graph.ts",
    "./rfc6902": "./src/-exports/-rfc6902.ts",
    "./url": "./src/-exports/-url.ts"
  }
}
