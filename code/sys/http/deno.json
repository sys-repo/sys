{
  "name": "@sys/http",
  "version": "0.0.261",
  "license": "MIT",
  "tasks": {
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check -- ./src/ ./-scripts/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "test": "deno test -P=test",
    "serve": "deno run -P=serve @sys/http/serve --cmd=start --port=1234 --dir='./src/-test/-sample.dist'",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/-exports/-http.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./client": "./src/-exports/-http.client.ts",
    "./server": "./src/-exports/-http.server.ts",
    "./serve": "./src/-serve/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    },
    "serve": {
      "read": true,
      "net": true
    }
  }
}

