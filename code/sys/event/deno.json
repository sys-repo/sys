{
  "name": "@sys/event",
  "version": "0.0.141",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./bus": "./src/-exports/-bus.ts",
    "./cmd": "./src/-exports/-cmd.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    }
  }
}

