{
  "name": "@sys/monorepo",
  "version": "0.0.14",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./ci": "./src/m.ci/mod.ts",
    "./pkg": "./src/m.pkg/mod.ts"
  },
  "permissions": {
    "clean": { "read": true, "write": true, "env": true },
    "test": { "read": true, "write": true, "env": true }
  }
}
