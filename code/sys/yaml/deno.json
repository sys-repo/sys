{
  "name": "@sys/yaml",
  "version": "0.0.67",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=testset",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/-clean.ts",
    "sample-cli": "deno run -P=testset ./-scripts/-sample-cli.ts",
    "tmp": "deno run -A ./-scripts/-tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./core": "./src/-exports/-core.ts",
    "./cli": "./src/m.cli/mod.ts"
  }
}
