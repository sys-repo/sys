{
  "name": "@sys/schema",
  "version": "0.0.146",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "tmp": "deno run -P=clean ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./primitives/t": "./src/t.typebox.primitives.ts",
    "./recipe": "./src/-exports/-core.recipe.ts",
    "./testing": "./src/-exports/-testing.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true
    }
  }
}
