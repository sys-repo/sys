{
  "name": "@sys/fs",
  "version": "0.0.290",
  "license": "MIT",
  "tasks": {
    "dry": "deno publish --allow-dirty --dry-run",
    "test": "deno test -P=test",
    "check": "deno check src/*",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "tmp": "deno run -P=clean ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./capability": "./src/m.Fs.capability/mod.ts",
    "./env": "./src/m.Env/mod.ts",
    "./dir": "./src/m.Dir/mod.ts",
    "./file": "./src/-exports/-file.ts",
    "./filemap": "./src/m.FileMap/mod.ts",
    "./path": "./src/m.Path/mod.ts",
    "./pkg": "./src/m.Pkg/mod.ts",
    "./watch": "./src/m.Watch/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true
    }
  }
}

