{
  "name": "@sys/ui-css",
  "version": "0.0.270",
  "license": "MIT",
  "tasks": {
    "dry": "deno publish --allow-dirty --dry-run",
    "check": "deno check -- ./src/ ./scripts/*",
    "clean": "deno run -P=clean ./scripts/task.clean.ts",
    "test": "deno test -P=test"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true
    }
  }
}

