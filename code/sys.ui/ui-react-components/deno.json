{
  "name": "@sys/ui-react-components",
  "version": "0.0.256",
  "license": "MIT",
  "tasks": {
    "test": "deno test -P=test",
    "prep": "deno run -P=dev ./-scripts/task.prep.ts",
    "dev": "deno run -P=dev ./-scripts/task.main.ts --cmd=dev --in=./src/index.html",
    "build": "deno run -P=dev ./-scripts/task.main.ts --cmd=build --in=./src/index.html",
    "serve": "deno run -P=dev ./-scripts/task.main.ts --cmd=serve",
    "check": "deno check src/",
    "dry": "deno publish --allow-dirty --dry-run",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "info": "deno run -P=dev ./-scripts/task.main.ts --cmd=info",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./action-probe": "./src/ui/ActionProbe/mod.ts",
    "./anchor": "./src/ui/Anchor/mod.ts",
    "./bullet": "./src/ui/Bullet/mod.ts",
    "./bullet-list": "./src/ui/BulletList/mod.ts",
    "./button": "./src/ui/Button/mod.ts",
    "./buttons": "./src/ui/Buttons/mod.ts",
    "./buttons/icons": "./src/ui/Buttons.Icons/mod.ts",
    "./buttons/switch": "./src/ui/Buttons.Switch/mod.ts",
    "./cropmarks": "./src/ui/Cropmarks/mod.ts",
    "./error-boundary": "./src/ui/ErrorBoundary/mod.ts",
    "./fade-element": "./src/ui/FadeElement/mod.ts",
    "./fonts": "./src/m.webfonts/mod.ts",
    "./http-origin": "./src/ui/Http.Origin/mod.ts",
    "./icon": "./src/ui/Icon/mod.ts",
    "./icon-swatches": "./src/ui/Icon.Swatches/mod.ts",
    "./iframe": "./src/ui/IFrame/mod.ts",
    "./image/svg": "./src/ui/Image.Svg/mod.ts",
    "./key-value": "./src/ui/KeyValue/mod.ts",
    "./layout/center-column": "./src/ui/Layout.CenterColumn/mod.ts",
    "./layout/rect-grid": "./src/ui/Layout.RectGrid/mod.ts",
    "./layout/split-pane": "./src/ui/Layout.SplitPane/mod.ts",
    "./layout/tabs": "./src/ui/Layout.Tabs/mod.ts",
    "./layout/tree-host": "./src/ui/Layout.TreeHost/mod.ts",
    "./media": "./src/ui/Media/mod.ts",
    "./media/recorder/dev": "./src/ui/Media.Recorder/-dev/mod.ts",
    "./media/timecode/playback-driver": "./src/ui/Media.Timecode.PlaybackDriver/mod.ts",
    "./object-view": "./src/ui/ObjectView/mod.ts",
    "./path-view": "./src/ui/PathView/mod.ts",
    "./player": "./src/ui/Player/mod.ts",
    "./player/youtube": "./src/ui/Player.YouTube/mod.ts",
    "./preload": "./src/ui/Preload/mod.ts",
    "./prose": "./src/ui/Prose/mod.ts",
    "./sheet": "./src/ui/Sheet/mod.ts",
    "./slider": "./src/ui/Slider/mod.ts",
    "./specs": "./src/-test/-specs.ts",
    "./spinners": "./src/ui/Spinners/mod.ts",
    "./text": "./src/ui/Text/mod.ts",
    "./tree-view": "./src/ui/TreeView/mod.ts",
    "./tree-view/index": "./src/ui/TreeView.Index/mod.ts",
    "./vimeo-background": "./src/ui/VimeoBackground/mod.ts"
  },
  "permissions": {
    "clean": {
      "read": true,
      "write": true,
      "env": true
    },
    "test": {
      "read": true,
      "write": true,
      "env": true,
      "net": true
    },
    "dev": {
      "read": true,
      "write": true,
      "run": true,
      "env": true,
      "net": true,
      "ffi": true,
      "sys": {
        "allow": [
          "cpus",
          "networkInterfaces",
          "hostname",
          "osRelease",
          "homedir",
          "uid",
          "gid"
        ]
      }
    }
  }
}

