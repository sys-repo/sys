{
  "name": "@sys/ui-react-components",
  "version": "0.0.202",
  "tasks": {
    "dev": "deno run -P=dev   ./-scripts/task.main.ts --cmd=dev    --in=./src/-test/index.html",
    "build": "deno run -P=build ./-scripts/task.main.ts --cmd=build  --in=./src/-test/index.html",
    "test": "deno test -P=testset",
    "serve": "deno run -P=serve ./-scripts/task.main.ts --cmd=serve",
    "check": "deno check src/*",
    "dry": "deno publish --allow-dirty --dry-run",
    "clean": "deno run -P=clean ./-scripts/task.clean.ts",
    "help": "deno run -P=dev   ./-scripts/task.main.ts --cmd=help",
    "tmp": "deno run -A ./-scripts/task.tmp.ts"
  },
  "exports": {
    ".": "./src/mod.ts",
    "./t": "./src/types.ts",
    "./types": "./src/types.ts",
    "./specs": "./src/-test/-specs.ts",
    "./fonts": "./src/m.webfonts/mod.ts",
    "./media/recorder/dev": "./src/ui/Media.Recorder/-dev/mod.ts",
    "./media/timecode/playback-driver": "./src/ui/Media.Timecode.PlaybackDriver/mod.ts"
  },
  "license": "MIT"
}
